{
  "name": "ethereum-archive",
  "homepage": "https://its-applekid.github.io/ethereum-archive/",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "gh-pages -d dist",
    "fetch-context-data": "tsx scripts/fetch-context-data.ts",
    "fetch-prices": "tsx scripts/fetch-data/fetch-eth-prices.ts",
    "fetch-gas": "tsx scripts/fetch-data/fetch-gas-prices.ts",
    "generate-block-context": "tsx scripts/fetch-data/generate-block-context.ts",
    "fetch-data": "npm run fetch-prices && npm run fetch-gas && npm run generate-block-context"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/three": "^0.183.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "gh-pages": "^6.3.0",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
